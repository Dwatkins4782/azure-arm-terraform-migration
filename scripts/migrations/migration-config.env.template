#!/bin/bash
# =============================================================================
# RBAC Migration Configuration Template
#
# Copy this file and fill in your values:
#   cp migration-config.env.template migration-config.env
#   vi migration-config.env
#
# Then run the migration:
#   ./rbac-migration.sh --config migration-config.env --dry-run
# =============================================================================

# ---------------------------------------------------------------------------
# Azure Subscription & Tenant
# ---------------------------------------------------------------------------
SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
TENANT_ID="00000000-0000-0000-0000-000000000000"

# ---------------------------------------------------------------------------
# Key Vault Configuration
# ---------------------------------------------------------------------------
# BLUE = your current vault (access policies, stays live during migration)
BLUE_VAULT_NAME="kv-platform-dev"

# GREEN = new vault name (will be created with RBAC enabled)
# Must be globally unique and not match any existing/soft-deleted vault
GREEN_VAULT_NAME="kv-platform-dev-rbac"

# Resource group where both vaults live (or will be created)
RESOURCE_GROUP="rg-platform-dev"
LOCATION="eastus"

# ---------------------------------------------------------------------------
# AKS Clusters
#
# Format: "cluster-name:resource-group"
# If resource group is omitted, RESOURCE_GROUP above is used.
#
# List ALL clusters that reference the blue Key Vault.
# ---------------------------------------------------------------------------
AKS_CLUSTERS=(
  "aks-dev-team-alpha:rg-platform-dev"
  "aks-dev-team-beta:rg-platform-dev"
  "aks-dev-integration:rg-platform-dev"
  "aks-dev-qa:rg-platform-dev"
  # Add all your clusters here...
)

# ---------------------------------------------------------------------------
# Canary Clusters
#
# These clusters are switched FIRST and validated before the batch rollout.
# Choose your least-critical cluster(s) for canary.
# ---------------------------------------------------------------------------
CANARY_CLUSTERS=(
  "aks-dev-team-alpha:rg-platform-dev"
)

# ---------------------------------------------------------------------------
# Batch Size
#
# How many clusters to switch in each batch during Phase 5.
# Smaller = safer but slower. Larger = faster but riskier.
# Default: 5
# ---------------------------------------------------------------------------
BATCH_SIZE=5

# ---------------------------------------------------------------------------
# Identity → RBAC Role Mapping
#
# Map each identity (object ID or service principal) to its RBAC role on the
# new vault. These replace the access policies from the blue vault.
#
# Common roles:
#   "Key Vault Secrets User"          — read secrets
#   "Key Vault Secrets Officer"       — read + write secrets
#   "Key Vault Crypto User"           — use keys for encrypt/decrypt
#   "Key Vault Crypto Officer"        — manage keys
#   "Key Vault Certificate User"      — read certificates
#   "Key Vault Certificates Officer"  — manage certificates
#   "Key Vault Administrator"         — full access
#
# Format: IDENTITY_ROLE_MAP["<object-id>"]="<role-name>"
# ---------------------------------------------------------------------------
declare -A IDENTITY_ROLE_MAP=(
  # AKS kubelet identity — needs to read secrets and use crypto keys
  ["00000000-0000-0000-0000-000000000001"]="Key Vault Secrets User"
  ["00000000-0000-0000-0000-000000000001"]="Key Vault Crypto User"

  # Pipeline service principal — needs to manage secrets
  ["00000000-0000-0000-0000-000000000002"]="Key Vault Secrets Officer"

  # Application managed identity — needs secret read
  ["00000000-0000-0000-0000-000000000003"]="Key Vault Secrets User"

  # DevOps team — needs admin access for management
  # ["00000000-0000-0000-0000-000000000004"]="Key Vault Administrator"
)

# ---------------------------------------------------------------------------
# Timeouts (seconds)
# ---------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=300    # How long to wait for health checks
ROLLBACK_TIMEOUT=600        # How long to allow for rollback
GATE_WAIT_TIMEOUT=60        # How long to wait at gate prompts
